<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IAMYOKA | Mariages</title>
    
    <!-- Favicon IAMYOKA (Généré en SVG) -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 fill=%22%23F9F8F6%22/><text x=%2250%22 y=%2272%22 font-family=%22serif%22 font-size=%2270%22 font-style=%22italic%22 font-weight=%22bold%22 fill=%22%23B5A898%22 text-anchor=%22middle%22>I</text></svg>" type="image/svg+xml">
   
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Playfair Display pour le côté éditorial/magazine, Jost pour la pureté moderne -->
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-paper': '#F9F8F6', /* Blanc cassé très doux */
                        'brand-ink': '#2C2A29',   /* Noir charbon (moins agressif que le noir pur) */
                        'brand-taupe': '#B5A898', /* Beige/Taupe élégant */
                        'brand-sand': '#EAE6DF',  /* Sable clair pour les fonds secondaires */
                        'brand-brown': '#5C4A41', /* Brun chaud pour le grand titre façon image */
                        'brand-peach': '#D9B3A0'  /* Pêche/Taupe clair pour le bouton de réservation */
                    },
                    fontFamily: {
                        serif: ['"Playfair Display"', 'serif'],
                        sans: ['"Jost"', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #F9F8F6;
            color: #2C2A29;
        }
        
        .fade-in-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .fade-in-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .hero-image {
            /* Image de montagne très lumineuse similaire à ta référence RENTHEM */
            background-image: url('https://images.unsplash.com/photo-1510076857177-7470076d4098?q=80&w=2072&auto=format&fit=crop');
            background-size: cover;
            background-position: center 20%;
            background-attachment: fixed;
        }
        
        /* Overlay blanc très léger en haut pour que le menu reste lisible */
        .hero-overlay {
            background: linear-gradient(to bottom, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0) 30%);
        }

        /* Lignes décoratives fines */
        .thin-line {
            height: 1px;
            background-color: #EAE6DF;
            width: 100%;
        }
    </style>
</head>
<body class="font-sans antialiased selection:bg-brand-taupe selection:text-white">

    <header class="absolute w-full top-0 z-50 py-8 px-6 md:px-12 flex justify-between items-center text-brand-ink">
        <div class="w-1/4">
            <a href="#" class="text-xl md:text-2xl font-sans font-bold tracking-widest uppercase">Iamyoka</a>
        </div>
        <nav class="hidden md:flex w-2/4 justify-center space-x-8 lg:space-x-12 text-[10px] tracking-[0.2em] uppercase font-light">
            <a href="#concept" class="hover:text-brand-taupe transition-colors duration-300">L'Approche</a>
            <a href="#processus" class="hover:text-brand-taupe transition-colors duration-300">Le Processus</a>
            <a href="#portfolio" class="hover:text-brand-taupe transition-colors duration-300">Portfolio</a>
            <a href="#tarifs" class="hover:text-brand-taupe transition-colors duration-300">Prestations</a>
            <a href="#contact" class="hover:text-brand-taupe transition-colors duration-300">Contact</a>
        </nav>
        <div class="w-1/4 flex justify-end">
            <a href="#contact" class="hidden md:inline-block bg-brand-peach text-white px-8 py-3 rounded-full text-[10px] uppercase tracking-[0.2em] hover:bg-brand-taupe transition-colors duration-300 shadow-sm">
                Réserver
            </a>
        </div>
    </header>

    <section class="relative h-screen flex items-center justify-center hero-image">
        <div class="absolute inset-0 hero-overlay"></div>
        <div class="relative z-10 text-center px-4 w-full max-w-5xl fade-in-up visible">
            <!-- Titre immense dans la couleur brun chaud de l'image -->
            <h1 class="text-6xl md:text-8xl lg:text-[11rem] font-serif text-brand-brown mb-2 tracking-tight" style="line-height: 0.9;">
                MARIAGES
            </h1>
            <p class="text-[10px] md:text-xs uppercase tracking-[0.3em] font-light text-brand-brown/70 mt-6">
                Votre mariage comme au cinéma
            </p>
        </div>
    </section>

    <section id="concept" class="py-24 md:py-32 px-6 md:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-16 items-center">
            
            <div class="md:col-span-5 fade-in-up">
                <h3 class="text-brand-taupe text-xs uppercase tracking-[0.2em] mb-6">Notre Approche</h3>
                <h2 class="text-4xl md:text-5xl font-serif mb-8 leading-tight">
                    Documentaire <br><span class="italic text-brand-taupe">Cinématographique</span>
                </h2>
                <div class="space-y-6 text-brand-ink/70 font-light text-sm md:text-base leading-relaxed">
                    <p>
                        Pour nous, votre mariage est un récit qui se doit d'être authentique. C'est pour cela que nous concevons un univers où le style photographique sur le vif s'allie à une atmosphère digne du 7ème art.
                    </p>
                    <p>
                        Des préparatifs jusqu'au jour J, nous travaillons pour respecter et traduire la vérité du jour où vous vous dites "oui". Pas de poses figées interminables, seulement vos rires francs, la lumière douce d'une fin d'après-midi, et l'intensité d'un regard.
                    </p>
                    <p class="font-medium text-brand-ink mt-8">
                        Basés à Toulouse. <br>Disponibles partout en France et à l'international.
                    </p>
                </div>
            </div>

            <div class="md:col-span-7 relative fade-in-up">
                <!-- Image décalée avec bordure fine style tableau -->
                <div class="relative p-4 bg-white shadow-sm">
                    <img src="https://images.unsplash.com/photo-1606800052052-a08af7148866?q=80&w=1974&auto=format&fit=crop" alt="Photographie documentaire" class="w-full h-[500px] md:h-[700px] object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-700">
                </div>
                <div class="absolute -bottom-10 -left-10 w-48 h-48 bg-brand-sand -z-10 hidden md:block"></div>
            </div>

        </div>
    </section>

    <section id="processus" class="py-24 bg-brand-paper px-4 md:px-12 border-t border-brand-sand">
        <div class="max-w-5xl mx-auto">
            
            <!-- En-tête de la section -->
            <div class="text-center mb-16 md:mb-24 fade-in-up">
                <div class="flex items-center justify-center mb-6">
                    <div class="h-px bg-brand-taupe/40 w-12 md:w-24"></div>
                    <span class="px-4 text-[10px] uppercase tracking-[0.2em] text-brand-taupe font-medium">L'Architecture du Souvenir</span>
                    <div class="h-px bg-brand-taupe/40 w-12 md:w-24"></div>
                </div>
                <h2 class="text-4xl md:text-5xl font-serif text-brand-ink">Le déroulé de votre film</h2>
            </div>

            <div class="relative">
                
                <!-- LE FIL D'ARIANE (Ligne verticale globale) - Désormais visible sur mobile -->
                <div class="absolute top-8 bottom-8 left-1/4 w-px bg-brand-taupe/50 transform -translate-x-1/2 z-0"></div>

                <!-- ÉTAPE 1 -->
                <div class="relative flex flex-row w-full mb-12 md:mb-20 fade-in-up z-10 group">
                    
                    <!-- Colonne Numéro (25%) -->
                    <div class="w-1/4 flex flex-col items-end pr-4 md:pr-12 pt-4 md:pt-8">
                        <div class="text-4xl md:text-7xl font-serif italic text-brand-taupe mb-1 md:mb-2 leading-none">I</div>
                        <div class="text-[8px] md:text-[10px] uppercase tracking-widest text-brand-ink/50 mt-2 md:mt-4 text-right">Premier Contact</div>
                    </div>

                    <!-- Le Point sur la ligne - Visible sur mobile, taille ajustée -->
                    <div class="absolute left-1/4 top-7 md:top-14 w-3 h-3 md:w-4 md:h-4 rounded-full border border-brand-taupe bg-brand-paper flex items-center justify-center transform -translate-x-1/2 -translate-y-1/2 group-hover:scale-125 transition-transform duration-300">
                        <div class="w-1 h-1 md:w-1.5 md:h-1.5 rounded-full bg-brand-taupe"></div>
                    </div>

                    <!-- Colonne Carte (75%) -->
                    <div class="w-3/4 pl-6 md:pl-12">
                        <div class="bg-white p-6 md:p-12 shadow-[0_4px_30px_rgba(0,0,0,0.02)] border border-brand-sand/40">
                            <div class="inline-block bg-brand-paper text-brand-ink px-3 py-1 md:px-4 md:py-1.5 text-[8px] md:text-[9px] uppercase tracking-[0.2em] mb-4 md:mb-6 font-medium">L'Échange</div>
                            <h4 class="text-2xl md:text-3xl font-serif text-brand-ink mb-3 md:mb-4">Autour d'un café</h4>
                            <p class="text-xs md:text-sm font-light text-brand-ink/70 leading-relaxed">
                                Vous nous racontez votre histoire et comment vous voyez votre mariage. Le but est d'apprendre à vous connaître et de ressentir votre sensibilité pour créer le film le plus proche de vous, du thème et de la volonté de votre mariage.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- ÉTAPE 2 -->
                <div class="relative flex flex-row w-full mb-12 md:mb-20 fade-in-up z-10 group">
                    <div class="w-1/4 flex flex-col items-end pr-4 md:pr-12 pt-4 md:pt-8">
                        <div class="text-4xl md:text-7xl font-serif italic text-brand-taupe mb-1 md:mb-2 leading-none">II</div>
                        <div class="text-[8px] md:text-[10px] uppercase tracking-widest text-brand-ink/50 mt-2 md:mt-4 text-right">Avant le mariage</div>
                    </div>
                    
                    <div class="absolute left-1/4 top-7 md:top-14 w-3 h-3 md:w-4 md:h-4 rounded-full border border-brand-taupe bg-brand-paper flex items-center justify-center transform -translate-x-1/2 -translate-y-1/2 group-hover:scale-125 transition-transform duration-300">
                        <div class="w-1 h-1 md:w-1.5 md:h-1.5 rounded-full bg-brand-taupe"></div>
                    </div>

                    <div class="w-3/4 pl-6 md:pl-12">
                        <div class="bg-white p-6 md:p-12 shadow-[0_4px_30px_rgba(0,0,0,0.02)] border border-brand-sand/40">
                            <div class="inline-block bg-brand-paper text-brand-ink px-3 py-1 md:px-4 md:py-1.5 text-[8px] md:text-[9px] uppercase tracking-[0.2em] mb-4 md:mb-6 font-medium">La Direction</div>
                            <h4 class="text-2xl md:text-3xl font-serif text-brand-ink mb-3 md:mb-4">Vision & Logistique</h4>
                            <p class="text-xs md:text-sm font-light text-brand-ink/70 leading-relaxed">
                                Nous vous présentons la direction artistique la plus adéquate que l'on a choisie pour votre mariage. Nous faisons ensuite un point sur la logistique et l'organisation pour que nous puissions coordonner nos équipes le grand jour.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- ÉTAPE 3 -->
                <div class="relative flex flex-row w-full mb-12 md:mb-20 fade-in-up z-10 group">
                    <div class="w-1/4 flex flex-col items-end pr-4 md:pr-12 pt-4 md:pt-8">
                        <div class="text-4xl md:text-7xl font-serif italic text-brand-taupe mb-1 md:mb-2 leading-none">III</div>
                        <div class="text-[8px] md:text-[10px] uppercase tracking-widest text-brand-ink/50 mt-2 md:mt-4 text-right">Le Grand Jour</div>
                    </div>
                    
                    <div class="absolute left-1/4 top-7 md:top-14 w-3 h-3 md:w-4 md:h-4 rounded-full border border-brand-taupe bg-brand-paper flex items-center justify-center transform -translate-x-1/2 -translate-y-1/2 group-hover:scale-125 transition-transform duration-300">
                        <div class="w-1 h-1 md:w-1.5 md:h-1.5 rounded-full bg-brand-taupe"></div>
                    </div>

                    <div class="w-3/4 pl-6 md:pl-12">
                        <div class="bg-white p-6 md:p-12 shadow-[0_4px_30px_rgba(0,0,0,0.02)] border border-brand-sand/40">
                            <div class="inline-block bg-brand-paper text-brand-ink px-3 py-1 md:px-4 md:py-1.5 text-[8px] md:text-[9px] uppercase tracking-[0.2em] mb-4 md:mb-6 font-medium">Le Tournage</div>
                            <h4 class="text-2xl md:text-3xl font-serif text-brand-ink mb-3 md:mb-4">Prise de vue</h4>
                            <p class="text-xs md:text-sm font-light text-brand-ink/70 leading-relaxed">
                                Le jour de votre mariage, place au tournage et à la prise de vue. Nous intervenons avec la plus grande discrétion pour capturer l'authenticité de chaque instant, des préparatifs jusqu'à la soirée.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- ÉTAPE 4 -->
                <div class="relative flex flex-row w-full fade-in-up z-10 group">
                    <div class="w-1/4 flex flex-col items-end pr-4 md:pr-12 pt-4 md:pt-8">
                        <div class="text-4xl md:text-7xl font-serif italic text-brand-taupe mb-1 md:mb-2 leading-none">IV</div>
                        <div class="text-[8px] md:text-[10px] uppercase tracking-widest text-brand-ink/50 mt-2 md:mt-4 text-right">Après le mariage</div>
                    </div>
                    
                    <div class="absolute left-1/4 top-7 md:top-14 w-3 h-3 md:w-4 md:h-4 rounded-full border border-brand-taupe bg-brand-paper flex items-center justify-center transform -translate-x-1/2 -translate-y-1/2 group-hover:scale-125 transition-transform duration-300">
                        <div class="w-1 h-1 md:w-1.5 md:h-1.5 rounded-full bg-brand-taupe"></div>
                    </div>

                    <div class="w-3/4 pl-6 md:pl-12">
                        <div class="bg-white p-6 md:p-12 shadow-[0_4px_30px_rgba(0,0,0,0.02)] border border-brand-sand/40">
                            <div class="inline-block bg-brand-paper text-brand-ink px-3 py-1 md:px-4 md:py-1.5 text-[8px] md:text-[9px] uppercase tracking-[0.2em] mb-4 md:mb-6 font-medium">La Livraison</div>
                            <h4 class="text-2xl md:text-3xl font-serif text-brand-ink mb-3 md:mb-4">Découverte de l'œuvre</h4>
                            <p class="text-xs md:text-sm font-light text-brand-ink/70 leading-relaxed">
                                Livraison de vos photos et de votre film via une galerie privée en ligne de haute qualité, avec la possibilité d'ajouter des supports physiques d'exception (coffret, album).
                            </p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section id="salon" class="py-20 bg-brand-ink text-brand-paper px-6">
        <div class="max-w-4xl mx-auto text-center fade-in-up">
            <span class="inline-block border border-brand-taupe text-brand-taupe px-4 py-1 text-xs uppercase tracking-[0.2em] mb-8">
                Exclusivité Salon du Mariage
            </span>
            <h2 class="text-3xl md:text-4xl font-serif mb-6 italic">Un cadeau pour votre grand jour</h2>
            <p class="font-light text-brand-paper/80 leading-relaxed mb-10 max-w-2xl mx-auto">
                Parce qu'une belle rencontre mérite d'être célébrée. Bénéficiez d'une réduction spéciale pour toute prise de contact suite à notre échange sur le salon, et d'une <strong class="text-brand-taupe font-normal">remise exceptionnelle supplémentaire</strong> pour toute réservation validée directement sur place.
            </p>
            <a href="#contact" class="inline-block bg-brand-taupe text-brand-ink px-10 py-4 text-xs uppercase tracking-[0.2em] hover:bg-brand-paper transition-colors duration-300">
                Profiter de l'offre
            </a>
        </div>
    </section>

    <section id="portfolio-films" class="py-24 bg-white px-6 md:px-12">
        <div class="max-w-7xl mx-auto">
            
            <div class="text-center mb-16 md:mb-20 fade-in-up">
                <div class="flex items-center justify-center mb-6">
                    <div class="h-px bg-brand-taupe/40 w-12 md:w-24"></div>
                    <span class="px-4 text-[10px] uppercase tracking-[0.2em] text-brand-taupe font-medium">Le Cinéma</span>
                    <div class="h-px bg-brand-taupe/40 w-12 md:w-24"></div>
                </div>
                <h2 class="text-4xl md:text-5xl font-serif text-brand-ink mb-4" id="portfolio">Vos souvenirs en mouvement</h2>
                <p class="text-brand-ink/50 font-light text-sm max-w-2xl mx-auto">L'intensité d'un regard, le souffle du vent, l'éclat d'un rire. Votre journée racontée comme une véritable œuvre cinématographique.</p>
            </div>

            <!-- Grille Vidéos -->
            <div class="space-y-6 md:space-y-12 fade-in-up">
                <!-- Vidéo Principale (Full width) -->
                <div class="group cursor-pointer relative">
                    <div class="relative aspect-video bg-brand-sand overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=2069&auto=format&fit=crop" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 grayscale-[10%] group-hover:grayscale-0">
                        <div class="absolute inset-0 bg-brand-ink/10 group-hover:bg-brand-ink/20 transition-colors duration-500"></div>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-16 h-16 md:w-20 md:h-20 bg-white/90 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-xl">
                                <svg class="w-6 h-6 md:w-8 md:h-8 text-brand-ink ml-1 md:ml-2" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>
                    </div>
                    <p class="mt-4 text-[10px] md:text-xs uppercase tracking-[0.2em] text-brand-ink/60 text-center font-medium">Film Long Format — Édition Cinéma</p>
                </div>

                <!-- Vidéos Secondaires (2 colonnes) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12">
                    <div class="group cursor-pointer relative">
                        <div class="relative aspect-[16/9] bg-brand-sand overflow-hidden">
                            <img src="https://images.unsplash.com/photo-1532712938310-34cb3982ef74?q=80&w=2070&auto=format&fit=crop" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 grayscale-[10%] group-hover:grayscale-0">
                            <div class="absolute inset-0 bg-brand-ink/10 group-hover:bg-brand-ink/20 transition-colors duration-500"></div>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <div class="w-12 h-12 md:w-16 md:h-16 bg-white/90 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-lg">
                                    <svg class="w-5 h-5 text-brand-ink ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                </div>
                            </div>
                        </div>
                        <p class="mt-4 text-[10px] md:text-xs uppercase tracking-[0.2em] text-brand-ink/60 text-center font-medium">Teaser — Rythme & Émotion</p>
                    </div>

                    <div class="group cursor-pointer relative">
                        <div class="relative aspect-[16/9] bg-brand-sand overflow-hidden">
                            <img src="https://images.unsplash.com/photo-1583939411023-14783179e581?q=80&w=2070&auto=format&fit=crop" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 grayscale-[10%] group-hover:grayscale-0">
                            <div class="absolute inset-0 bg-brand-ink/10 group-hover:bg-brand-ink/20 transition-colors duration-500"></div>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <div class="w-12 h-12 md:w-16 md:h-16 bg-white/90 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-lg">
                                    <svg class="w-5 h-5 text-brand-ink ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                </div>
                            </div>
                        </div>
                        <p class="mt-4 text-[10px] md:text-xs uppercase tracking-[0.2em] text-brand-ink/60 text-center font-medium">Élopement — Intimité</p>
                    </div>
                </div>
            </div>
            
        </div>
    </section>

    <section id="portfolio-photos" class="py-24 bg-brand-paper px-6 md:px-12 border-t border-brand-sand/50">
        <div class="max-w-7xl mx-auto">
            
            <div class="text-center mb-16 md:mb-20 fade-in-up">
                <div class="flex items-center justify-center mb-6">
                    <div class="h-px bg-brand-taupe/40 w-12 md:w-24"></div>
                    <span class="px-4 text-[10px] uppercase tracking-[0.2em] text-brand-taupe font-medium">Le Documentaire</span>
                    <div class="h-px bg-brand-taupe/40 w-12 md:w-24"></div>
                </div>
                <h2 class="text-4xl md:text-5xl font-serif text-brand-ink mb-4">L'art de figer l'instant</h2>
                <p class="text-brand-ink/50 font-light text-sm max-w-2xl mx-auto">Aucune pose figée, seulement la vérité de votre journée. Un mélange de lumière pure et d'ombres intimes.</p>
            </div>

            <!-- Grille Photos Style Éditorial / Magazine -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-6 fade-in-up">
                
                <!-- Grande photo (Lumineux) -->
                <div class="md:col-span-2 md:row-span-2 group overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1541250848049-b4f7146120ef?q=80&w=1974&auto=format&fit=crop" class="w-full h-[400px] md:h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 grayscale-[20%] hover:grayscale-0">
                </div>

                <!-- Moyenne photo horizontale (Moody) -->
                <div class="md:col-span-2 group overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1469334031218-e382a71b716b?q=80&w=2070&auto=format&fit=crop" class="w-full h-[300px] md:h-[400px] object-cover transform group-hover:scale-105 transition-transform duration-1000 grayscale-[20%] hover:grayscale-0">
                </div>

                <!-- Deux petites photos verticales (Détails / Portrait) -->
                <div class="md:col-span-1 group overflow-hidden">
